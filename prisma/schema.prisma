// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-ts"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum EtatFacture {
  a_payer
  payer
}

model Localite {
  id_localite  Int      @id @default(autoincrement())
  code_postale String?
  province     String?
  localite     String?

  adresses Adresse[]
}

model Adresse {
  id_adresse Int    @id @default(autoincrement())
  rue        String
  numero     String
  boite      String

  id_localite Int?
  localite    Localite? @relation(fields: [id_localite], references: [id_localite])

  clients Client[]
}

model Client {
  
  id_client Int    @id @default(autoincrement())
  nom       String
  prenom    String
  email     String? @unique

  id_adresse Int?
  adresse    Adresse? @relation(fields: [id_adresse], references: [id_adresse])

  factures Facture[]
}

model Categorie {
  id_cat   Int    @id @default(autoincrement())
  intitule String?

  sous_categories Sous_categorie[]
}

model Sous_categorie {
  id_sous_cat       Int    @id @default(autoincrement())
  intitule_sous_cat String?

  id_cat    Int?
  categorie Categorie? @relation(fields: [id_cat], references: [id_cat])

  produits ProduitStock[]
}

model ProduitStock {
  id_produit       Int     @id @default(autoincrement())
  urlImage         String?
  intitule_produit String?
  quantite         Int?
  prix_unitaire    Decimal?
  id_sous_cat   Int?
  sous_categorie Sous_categorie? @relation(fields: [id_sous_cat], references: [id_sous_cat])
  produitCommandes ProduitCommande[]
}

model ProduitCommande {
  id_commande Int
  id_produit  Int
  id_facture  Int
  quantite    Int?

  produit ProduitStock @relation(fields: [id_produit], references: [id_produit])
  facture Facture      @relation(fields: [id_facture], references: [id_facture],onDelete: Cascade)

  @@id([id_commande, id_produit])
}

model Facture {
  id_facture Int      @id @default(autoincrement())
  id_client  Int?

  date_paiement DateTime?
  moyen        String?
  montant      Decimal?

  etat EtatFacture @default(a_payer)

  client Client? @relation(fields: [id_client], references: [id_client], onDelete: Cascade)

  produits ProduitCommande[]
}